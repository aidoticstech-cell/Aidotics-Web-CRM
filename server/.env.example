# Same Postgres as Partner backend (CRM uses schema "crm")
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=crm"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=crm"

PORT=4100

JWT_SECRET="long_random_crm_jwt_secret"
JWT_REFRESH_SECRET="long_random_crm_refresh_secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Partner backend (Aidotics platform) — only used by duties/workforce routes and optional register sync.
PARTNER_API_URL="http://localhost:4000"
PARTNER_CRM_SERVICE_SECRET="shared_secret_with_partner_backend"

# Set to true only if this CRM should create the bureau in the partner API on /auth/register
# and use that service’s bureau id. Default is standalone CRM (local UUID on Bureau.partnerBureauId).
# PARTNER_SYNC_ON_REGISTER=true

# Public URL of your CRM web app (for website "Open CRM" / onboarding deep links)
CRM_WEB_URL="https://crm.aidotics.com"

# Supabase — Aidotics-Web-CRM only (ref lsveivwgzevtoyqhqvyi)
SUPABASE_URL="https://lsveivwgzevtoyqhqvyi.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # Dashboard → Settings → API → service_role (never commit)
# SUPABASE_DOCUMENTS_BUCKET="crm-documents"

# Dev OTP (when NODE_ENV=development)
OTP_IN_RESPONSE=true
NODE_ENV=development
